{
  "name": "threejs-bim-svg-export",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "concurrently \"tsx watch src/server/server.ts\" \"vite\"",
    "build": "vite build && tsc -p tsconfig.server.json",
    "preview": "vite preview",
    "server": "node dist-server/server.js",
    "start": "concurrently \"npm run server\" \"npm run preview -- --host 0.0.0.0 --port 4173\""
  },
  "dependencies": {
    "@types/three": "^0.183.1",
    "cors": "^2.8.6",
    "express": "^4.21.2",
    "multer": "^1.4.5-lts.2",
    "sharp": "^0.34.2",
    "svgo": "^3.3.2",
    "three": "^0.180.0"
  },
  "devDependencies": {
    "@types/cors": "^2",
    "@types/express": "^5.0.3",
    "@types/multer": "^1.4.13",
    "@types/node": "^24.0.3",
    "concurrently": "^9.2.0",
    "tsx": "^4.21.0",
    "typescript": "^5.8.3",
    "vite": "^7.0.0"
  }
}
